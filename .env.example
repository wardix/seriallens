# Google Gemini API Key - Dapatkan di https://aistudio.google.com/
GOOGLE_API_KEY=your_api_key_here

# Port untuk menjalankan server (Default: 3000)
PORT=3000

# Model Gemini yang digunakan (Default: gemini-2.0-flash)
# Pilihan lain dari list: gemini-3.1-flash-image-preview, gemini-2.5-flash, dll.
GEMINI_MODEL=gemini-2.0-flash

# API Key untuk mengamankan Web Service SerialLens (Opsional, tapi disarankan)
# Jika diisi, request harus menyertakan header 'x-api-key'
API_KEY=your_secret_app_key_here

